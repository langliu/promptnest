{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "jsxSingleQuote": true,
  "semi": false,
  "sortImports": true,
  "sortPackageJson": {
    "sortScripts": true
  },
  "sortTailwindcss": true,
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    ".wrangler/**",
    ".nitro/**",
    ".output/**",
    ".tanstack/**",
    "src/routeTree.gen.ts",
    "worker-configuration.d.ts"
  ]
}
